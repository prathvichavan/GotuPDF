@import "tailwindcss";
@plugin "@tailwindcss/typography";

/* ========================================
   GOTUPDF PREMIUM DARK DESIGN SYSTEM
   ======================================== */

:root {
  color-scheme: dark;

  /* Dark Theme Core */
  --bg-primary: #0a0e1a;
  --bg-secondary: #0f1629;
  --bg-tertiary: #151d35;
  --bg-card: rgba(15, 22, 41, 0.6);

  /* Text */
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-tertiary: #64748b;
  --text-muted: #475569;

  /* Borders */
  --border-primary: rgba(99, 102, 241, 0.15);
  --border-secondary: rgba(99, 102, 241, 0.08);
  --border-glow: rgba(99, 102, 241, 0.3);

  /* Accent */
  --accent-primary: #818cf8;
  --accent-hover: #6366f1;
  --accent-glow: rgba(99, 102, 241, 0.4);

  /* Glass */
  --glass-bg: rgba(15, 22, 41, 0.5);
  --glass-border: rgba(99, 102, 241, 0.12);
  --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);

  /* Status */
  --success: #34d399;
  --error: #f87171;
  --warning: #fbbf24;

  /* Upload */
  --upload-bg: rgba(15, 22, 41, 0.4);
  --upload-border: rgba(99, 102, 241, 0.2);
  --upload-hover-bg: rgba(99, 102, 241, 0.06);
  --upload-hover-border: rgba(99, 102, 241, 0.5);
  --upload-text: #94a3b8;

  /* Input */
  --input-bg: rgba(15, 22, 41, 0.6);
  --input-border: rgba(99, 102, 241, 0.15);
  --input-focus: #818cf8;
  --input-text: #f1f5f9;
  --input-placeholder: #475569;

  /* Card */
  --card-bg: rgba(15, 22, 41, 0.5);
  --card-border: rgba(99, 102, 241, 0.1);
  --card-shadow: rgba(0, 0, 0, 0.2);

  /* Legacy */
  --background: #0a0e1a;
  --foreground: #f1f5f9;
}

@theme inline {
  --color-background: var(--background, #0a0e1a);
  --color-foreground: var(--foreground, #f1f5f9);
  --font-sans: var(--font-inter, "Inter");
  --font-mono: var(--font-geist-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace);
}

/* ========================================
   BASE STYLES
   ======================================== */

html {
  background-color: var(--bg-primary);
  color: var(--text-primary);
  text-size-adjust: 100%;
  -webkit-text-size-adjust: 100%;
  scroll-behavior: smooth;
}

body {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: var(--font-inter, "Inter"), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
}

/* ========================================
   TYPOGRAPHY
   ======================================== */

h1, h2, h3, h4, h5, h6 {
  color: var(--text-primary);
  font-weight: 700;
}

p, span, div {
  color: var(--text-secondary);
}

/* ========================================
   GRADIENT UTILITIES
   ======================================== */

.gradient-text {
  background: linear-gradient(135deg, #818cf8 0%, #a78bfa 30%, #c084fc 60%, #818cf8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.gradient-primary {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #2563eb 100%);
}

.gradient-bg-hero {
  background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99, 102, 241, 0.15) 0%, transparent 60%),
              radial-gradient(ellipse 60% 50% at 80% 50%, rgba(124, 58, 237, 0.08) 0%, transparent 50%),
              radial-gradient(ellipse 60% 50% at 20% 50%, rgba(37, 99, 235, 0.08) 0%, transparent 50%),
              var(--bg-primary);
}

.gradient-bg-section {
  background: radial-gradient(ellipse 70% 40% at 50% 0%, rgba(99, 102, 241, 0.06) 0%, transparent 70%),
              var(--bg-secondary);
}

/* ========================================
   GLASSMORPHISM
   ======================================== */

.glass {
  background: var(--glass-bg);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid var(--glass-border);
  box-shadow: var(--glass-shadow);
}

.glass-card {
  background: rgba(15, 22, 41, 0.4);
  backdrop-filter: blur(12px) saturate(150%);
  -webkit-backdrop-filter: blur(12px) saturate(150%);
  border: 1px solid rgba(99, 102, 241, 0.1);
  border-radius: 1.5rem;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-card:hover {
  border-color: rgba(99, 102, 241, 0.25);
  box-shadow: 0 0 30px rgba(99, 102, 241, 0.08), 0 8px 32px rgba(0, 0, 0, 0.2);
  transform: translateY(-2px);
}

.glass-subtle {
  background: rgba(15, 22, 41, 0.3);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(99, 102, 241, 0.06);
}

/* ========================================
   GLOW EFFECTS
   ======================================== */

.glow-border {
  position: relative;
}

.glow-border::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.3), rgba(124, 58, 237, 0.15), rgba(37, 99, 235, 0.3));
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.glow-border:hover::before {
  opacity: 1;
}

.glow-icon {
  filter: drop-shadow(0 0 8px var(--accent-glow));
}

.glow-text {
  text-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
}

/* ========================================
   FORMS
   ======================================== */

input:not([type="checkbox"]):not([type="radio"]),
textarea,
select {
  background-color: var(--input-bg);
  color: var(--input-text);
  border-color: var(--input-border);
  transition: all 150ms ease-out;
  outline: none;
}

input::placeholder,
textarea::placeholder {
  color: var(--input-placeholder);
  opacity: 1;
}

input:not([type="checkbox"]):not([type="radio"]):focus,
textarea:focus,
select:focus {
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  border-color: var(--input-focus);
}

input:disabled,
textarea:disabled,
select:disabled {
  cursor: not-allowed;
  background-color: var(--bg-tertiary);
  color: var(--text-muted);
}

input[type="number"].no-spinner {
  appearance: textfield;
  -moz-appearance: textfield;
}
input[type="number"].no-spinner::-webkit-outer-spin-button,
input[type="number"].no-spinner::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

/* ========================================
   BUTTONS
   ======================================== */

button, .btn, a[role="button"],
input[type="submit"], input[type="button"] {
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  font-weight: 500;
}

button:hover:not(:disabled),
.btn:hover:not(:disabled) {
  transform: translateY(-1px);
}

button:active:not(:disabled),
.btn:active:not(:disabled) {
  transform: translateY(0);
}

button:disabled,
.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-primary {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  color: white;
  border: none;
  border-radius: 0.75rem;
  padding: 0.75rem 2rem;
  font-weight: 600;
  position: relative;
  overflow: hidden;
}

.btn-primary::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.btn-primary:hover::after {
  opacity: 1;
}

.btn-primary > * {
  position: relative;
  z-index: 1;
}

.btn-ghost {
  background: rgba(99, 102, 241, 0.1);
  color: #a5b4fc;
  border: 1px solid rgba(99, 102, 241, 0.2);
  border-radius: 0.75rem;
  padding: 0.75rem 2rem;
  font-weight: 600;
}

.btn-ghost:hover {
  background: rgba(99, 102, 241, 0.15);
  border-color: rgba(99, 102, 241, 0.4);
}

/* ========================================
   UPLOAD AREAS
   ======================================== */

.upload-area,
[class*="border-dashed"] {
  background-color: var(--upload-bg);
  border-color: var(--upload-border);
  color: var(--upload-text);
  transition: all 200ms ease-out;
}

.upload-area:hover,
[class*="border-dashed"]:hover {
  border-color: var(--upload-hover-border);
  background-color: var(--upload-hover-bg);
}

/* ========================================
   CARDS & CONTAINERS
   ======================================== */

.card, .tool-card {
  background-color: var(--card-bg);
  border-color: var(--card-border);
  transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

.card:hover, .tool-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px var(--card-shadow);
}

/* ========================================
   LINKS
   ======================================== */

a {
  color: var(--accent-primary);
  transition: color 150ms ease-out;
}

a:hover {
  color: var(--accent-hover);
}

nav a {
  position: relative;
  color: var(--text-secondary);
  transition: color 150ms ease-out;
}

nav a:hover {
  color: var(--accent-primary);
}

nav a::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, #818cf8, #a78bfa);
  transition: width 200ms ease-out;
}

nav a:hover::after {
  width: 100%;
}

footer a {
  color: rgb(148, 163, 184) !important;
  text-decoration: none;
}

footer a:hover {
  color: rgb(226, 232, 240) !important;
}

footer a[aria-label="Instagram"]:hover {
  color: rgb(244, 114, 182) !important;
}

/* ========================================
   ANIMATIONS
   ======================================== */

@keyframes page-fade-in {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fade-in 0.5s ease-out;
}

main {
  animation: page-fade-in 300ms ease-out;
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-8px) rotate(1deg); }
  66% { transform: translateY(4px) rotate(-1deg); }
}

.animate-float {
  animation: float 6s ease-in-out infinite;
}

.animate-float-delay-1 {
  animation: float 7s ease-in-out 1s infinite;
}

.animate-float-delay-2 {
  animation: float 8s ease-in-out 2s infinite;
}

@keyframes slide-up {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.animate-slide-up {
  animation: slide-up 0.5s ease-out;
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
  50% { box-shadow: 0 0 20px 4px rgba(99, 102, 241, 0.2); }
}

.animate-pulse-glow {
  animation: pulse-glow 3s ease-in-out infinite;
}

@keyframes gentle-pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(99, 102, 241, 0);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 0 0 8px rgba(99, 102, 241, 0.2);
    transform: scale(1.02);
  }
}

@keyframes counter-up {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-counter {
  animation: counter-up 0.6s ease-out forwards;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.animate-shimmer {
  background: linear-gradient(90deg, transparent 0%, rgba(99, 102, 241, 0.06) 50%, transparent 100%);
  background-size: 200% 100%;
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes connecting-line {
  from { width: 0; }
  to { width: 100%; }
}

/* ========================================
   LOADING STATES
   ======================================== */

.loading {
  pointer-events: none;
}

/* ========================================
   ACCESSIBILITY
   ======================================== */

*:focus-visible {
  outline: 2px solid var(--accent-primary);
  outline-offset: 2px;
}

a:focus-visible,
button:focus-visible {
  outline: 3px solid var(--accent-primary);
  outline-offset: 3px;
  border-radius: 4px;
}

* { box-sizing: border-box; }
img, video { max-width: 100%; height: auto; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* ========================================
   SCROLLBAR
   ======================================== */

::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-primary);
}

::-webkit-scrollbar-thumb {
  background: rgba(99, 102, 241, 0.2);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(99, 102, 241, 0.4);
}

/* ========================================
   ANTIGRAVITY BACKGROUND
   ======================================== */

.antigravity-background {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.antigravity-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* ========================================
   LAYOUT
   ======================================== */

section { width: 100%; }

.content-wrapper {
  width: 100%;
  margin-left: auto;
  margin-right: auto;
  padding-left: 1.5rem;
  padding-right: 1.5rem;
}

@media (min-width: 640px) {
  .content-wrapper { padding-left: 2rem; padding-right: 2rem; }
}
@media (min-width: 1024px) {
  .content-wrapper { padding-left: 3rem; padding-right: 3rem; }
}
@media (min-width: 1280px) {
  .content-wrapper { padding-left: 4rem; padding-right: 4rem; }
}

/* ========================================
   PRINT
   ======================================== */

@media print {
  body { background: white; color: black; }
}

/* Gradient text fallback */
@supports not ((-webkit-background-clip: text) or (background-clip: text)) {
  .bg-clip-text.text-transparent,
  .gradient-text {
    color: var(--text-primary);
    -webkit-text-fill-color: currentColor;
    background-image: none;
  }
}

/* ========================================
   PROSE OVERRIDES FOR DARK THEME
   ======================================== */

.prose {
  --tw-prose-body: var(--text-secondary);
  --tw-prose-headings: var(--text-primary);
  --tw-prose-links: var(--accent-primary);
  --tw-prose-bold: var(--text-primary);
  --tw-prose-counters: var(--text-tertiary);
  --tw-prose-bullets: var(--text-tertiary);
  --tw-prose-hr: var(--border-primary);
  --tw-prose-quotes: var(--text-secondary);
  --tw-prose-quote-borders: var(--border-primary);
  --tw-prose-code: var(--accent-primary);
}
